datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  password             String
  name                 String
  role                 String    // "learner" | "mentor" | "admin"
  isEmailVerified      Boolean   @default(false)
  verificationToken    String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  tokenBalance         Int       @default(30)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Profile additions
  avatarUrl            String?
  bio                  String?
  hourlyRate           Int       @default(1000)
  skills               String?   // JSON-stringified array
  availabilityDays     String?   // JSON-stringified array
  availabilitySlots    String?   // JSON-stringified array
  isMentorApproved     Boolean   @default(false)
  targetHours          String?   // "Light", "Moderate", "Intense", etc.
  interests            String?   // JSON-stringified array (learner interests)
  careerGoal           String?
  linkedinUrl          String?
  isOnboarded          Boolean   @default(false)

  // Subscription
  subscriptionPlan     String?   // "all_access" | null
  subscriptionStatus   String?   // "active" | "cancelled" | "expired"
  subscriptionExpiry   DateTime? // end of current paid period

  // Skill Exchange
  skillsList           String    @default("[]") // JSON array of skills the user knows
}

model Course {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String
  price       Int      @default(1000) // Price in BDT
  published   Boolean  @default(true)
  lessons     String   // JSON-stringified array of lessons [{ id, title, duration, videoUrl }]
  mentorId    String
  mentorName  String
  createdAt   DateTime @default(now())
}

model Enrollment {
  id               String   @id @default(uuid())
  userId           String
  courseId         String
  completedLessons String   @default("[]") // JSON-stringified array of completed lesson IDs
  createdAt        DateTime @default(now())
}

model Review {
  id          String   @id @default(uuid())
  rating      Int      // 1 to 5
  comment     String
  studentId   String
  studentName String
  targetId    String   // courseId or mentorId
  type        String   // "course" | "mentor"
  createdAt   DateTime @default(now())
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Booking {
  id         String   @id @default(uuid())
  studentId  String
  mentorId   String
  mentorName String
  topic      String
  date       String
  time       String
  price      Int      @default(1000) // cost in BDT ৳
  status     String   @default("pending") // "pending" | "confirmed" | "rejected" | "disputed" | "refunded"
  createdAt  DateTime @default(now())
}

model SkillPost {
  id               String   @id @default(uuid())
  authorId         String
  authorName       String
  offeredSkill     String
  recommendedSkill String
  description      String?
  tokenCost        Int      @default(5)
  isOpen           Boolean  @default(true)
  createdAt        DateTime @default(now())
}

model SkillExchangeRequest {
  id            String   @id @default(uuid())
  postId        String
  requesterId   String
  requesterName String
  type          String   // "barter" | "token"
  offeredSkill  String?
  message       String?
  status        String   @default("pending") // "pending" | "accepted" | "rejected"
  tokensSpent   Int      @default(0)
  createdAt     DateTime @default(now())
}

model Payment {
  id           String   @id @default(uuid())
  userId       String
  amount       Int      // Amount in BDT
  type         String   // "course_enrollment" | "consultation_booking" | "wallet_topup" | "subscription"
  status       String   // "success" | "failed" | "refunded"
  gatewayTxnId String   // Transaction ID (e.g. bKash/Nagad mock)
  createdAt    DateTime @default(now())
}
